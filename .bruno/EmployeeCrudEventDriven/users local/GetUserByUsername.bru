meta {
  name: GetUserByUsername
  type: http
  seq: 3
}

get {
  url: http://localhost:8084/users/username/{{username}}
  body: none
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{auth_token}}
}

vars:pre-request {
  username: john@test.com
}

settings {
  encodeUrl: false
  timeout: 0
}
