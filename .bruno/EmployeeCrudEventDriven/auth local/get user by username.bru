meta {
  name: get user by username
  type: http
  seq: 6
}

get {
  url: http://localhost:8081/admin/realms/dev/users?username=john@test.com&exact=true
  body: none
  auth: bearer
}

params:query {
  username: john@test.com
  exact: true
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
