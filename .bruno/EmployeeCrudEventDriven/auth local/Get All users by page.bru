meta {
  name: Get All users by page
  type: http
  seq: 7
}

get {
  url: http://localhost:8081/admin/realms/dev/users?first=50&max=50
  body: none
  auth: bearer
}

params:query {
  first: 50
  max: 50
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
