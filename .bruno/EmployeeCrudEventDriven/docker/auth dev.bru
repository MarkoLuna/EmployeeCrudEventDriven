meta {
  name: auth dev
  type: http
  seq: 3
}

post {
  url: http://localstack.lks.com:8080/auth/realms/dev/protocol/openid-connect/token
  body: formUrlEncoded
  auth: inherit
}

headers {
  content-type: application/x-www-form-urlencoded
  Host: localstack.lks.com:8080
}

body:form-urlencoded {
  client_id: newClient
  client_secret: newClientSecret
  username: john@test.com
  password: 123
  grant_type: password
}

script:post-response {
  var jsonData = res.getBody();
  if (jsonData["access_token"] != null) {
      bru.setEnvVar("auth_token", jsonData["access_token"]);
  }
  if (jsonData["token_type"] != null) {
      bru.setEnvVar("auth_type", jsonData["token_type"]);
  }
}

settings {
  encodeUrl: false
  timeout: 0
}
